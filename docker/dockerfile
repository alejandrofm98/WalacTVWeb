# Etapa 1: Build de Angular
FROM node:20-alpine AS builder

WORKDIR /app

# Copiar archivos de dependencias
COPY package*.json ./

# Instalar dependencias
RUN npm ci --legacy-peer-deps

# Copiar todo el código fuente
COPY . .

# ARGs que vienen de Dokploy
ARG APP_NAME
ARG IPTV_API_URL
ARG API_WALACTV
ARG ACESTREAM_HOST
ARG ADMIN_EMAILS

# 🔧 Crear environment.ts dinámicamente para que Angular compile correctamente
RUN printf "export const environment = {\n  production: true,\n  appName: '%s',\n  apiWalactv: '%s',\n  acestreamHost: '%s',\n  iptvApiUrl: '%s',\n  adminEmails: ['%s']\n};\n" \
  "$APP_NAME" \
  "$API_WALACTV" \
  "$ACESTREAM_HOST" \
  "$IPTV_API_URL" \
  "$ADMIN_EMAILS" > src/environments/environment.ts

# Compilar Angular en modo producción
RUN npm run build -- --configuration production

# Etapa 2: Servir con http-server
FROM node:20-alpine

WORKDIR /app

# Instalar http-server globalmente
RUN npm install -g http-server

# Copiar los archivos compilados
COPY --from=builder /app/dist/walactvWeb/browser ./dist

EXPOSE 8080

CMD ["http-server", "./dist", "-p", "8080", "-c-1", "--proxy", "http://localhost:8080?"]
